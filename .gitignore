# ============================================================
# .gitignore — StockSight AI
# ============================================================

# ── Python Cache ──
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Virtual Environments ──
venv/
env/
.env/
.venv/

# ── Jupyter ──
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──
*.log
logs/

# ── Data exports (keep raw CSVs but not generated outputs) ──
data/*.html

# ── Secrets & Config ──
.env
secrets.toml
.streamlit/secrets.toml

# ── Dist / Build ──
dist/
build/
*.egg-info/
